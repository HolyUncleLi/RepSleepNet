
{
    "dataset": {
        "name": "Sleep-EDF-2013",
        "eeg_channel": "Fpz-Cz",
        "num_splits": 20,
        "seq_len": 10,
        "sampleing_rate": 100,
        "target_idx": -1,
        "root_dir": "./"
    },
    "backbone": {
        "name": "ProtoP",
        "init_weights": false,
        "dropout": false
    },
    "feature_pyramid": {
        "dim": 1,
        "num_scales": 3
    },
    "classifier": {
        "name": "ProtoP",
        "prototype_shape": [20, 128, 15],
        "feedforward_dim": 64,
        "block_num": 6,
        "channel_num": 128,
        "kernel_size": 9,
        "repeat_num": 3,
        "strides_num": 1,
        "afr_reduced_dim": 128,
        "prototype_num": 20,
        "feature_dim": 64,

        "class_lambda": 50,
        "dist_lambda": 17.8373,
        "diversity_lambda": 5.0,
        "identity_lambda": 8.9351,
        "pd_lambda": 7.9252,
        "gabor_spec_lambda": 1.5,
        "fourier_spec_lambda": 1.5,
        "orth_lambda": 0.1,
        "weight_lambda": 0.001,

        "num_classes": 5,
        "pos_enc": {
            "dropout": false
        }
    },
    "training_params": {
        "mode": "freezefinetune",
        "max_epochs": 1,
        "batch_size": 64,
        "lr": 0.0005,
        "weight_decay": 0.0001,
        "val_period": 50,
        "early_stopping": {
            "mode": "max",
            "patience": 50
        }
    },
    "protop_mode": "normal" 
}
